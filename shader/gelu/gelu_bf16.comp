#version 460
#extension GL_EXT_bfloat16 : enable
#extension GL_EXT_shader_explicit_arithmetic_types : enable
#extension GL_EXT_shader_explicit_arithmetic_types_int64 : enable

layout(local_size_x = 256) in;

layout(push_constant) uniform Params {
    uint64_t total_elements;
};

layout(std430, binding = 0) readonly buffer Src { bfloat16_t src[]; };
layout(std430, binding = 1) writeonly buffer Dst { bfloat16_t dst[]; };

void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx >= total_elements) return;
    float x = float(src[idx]);
    float c = 0.7978845608028654;
    dst[idx] = bfloat16_t(0.5 * x * (1.0 + tanh(c * (x + 0.044715 * x * x * x))));
}
